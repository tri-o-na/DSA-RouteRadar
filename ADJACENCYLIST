import json

file_path = 'Data/airline_routes_custom.json' 
with open(file_path) as file:
    data = json.load(file)

def InitAdjacencyList(data):
    adjacency_list = {}  # Initialize an empty adjacency list

    for airport, details in data.items():
        adjacency_list[airport] = []  # Initialize an empty list for each airport

        # Iterate through all the routes for each airport
        for route in details["routes"]:
            dest_code = route["airport_code"]  # Get destination airport code
            route_info = []

            # Extract route information (airline, duration, distance, base price)
            for airline in route["airlines"]:
                airline_code = airline["airline_code"]
                airline_name = airline["airline_name"]
                duration = route["duration"]
                distance = route["distance"]
                base_price = route["base_price"]

                route_info.append((dest_code, airline_code, airline_name, duration, distance, base_price))
                
            # Add the route information to the adjacency list
            adjacency_list[airport].extend(route_info)

    return adjacency_list

# Call the function using the `data` variable loaded from the JSON file
adj_list = InitAdjacencyList(data)

# Print result (optional)
print("Adjacency List:\n", adj_list)
