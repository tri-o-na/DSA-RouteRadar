ScreenManager:
    FirstScreen:
    SecondScreen:

<FirstScreen>:
    BoxLayout:
        orientation: 'horizontal'
        size_hint: 1,1

        # Left side: User input fields
        BoxLayout:
            orientation: 'vertical'
            size_hint: None, None  # Disable automatic resizing
            size: "400dp", "300dp"  # You can adjust the size as needed
            pos_hint: {"center_x": 0.5, "center_y": 0.5}  # Center the BoxLayout
            padding:100
            

            # Text Input 1 for Departing Airport
            TextInput:
                id: text_input1
                hint_text: "Departing Airport"
                size_hint_y: None
                height: "40dp"  # Adjust height to make the field smaller
                multiline: False
                padding_x: 10
                padding_y: 5
                # Make the input box not too wide and centered

            # Text Input 2 for Arriving Airport
            TextInput:
                id: text_input2
                hint_text: "Arriving Airport"
                size_hint_y: None
                height: "40dp"  # Adjust height to make the field smaller
                multiline: False
                padding_x: 10
                padding_y: 5

            # Date Input
            TextInput:
                id: date_input
                hint_text: "Flight Date"
                size_hint_y: None
                height: "40dp"  # Adjust height
                multiline: False
                padding_x: 10
                padding_y: 5

            # Submit Button
            Button:
                text: "Search Routes"
                size_hint_y: None
                height: "50dp"
                on_press: root.on_submit()  # Trigger the submit function
                font_size: "18sp"
                background_color: [0.2, 0.6, 0.2, 1]  # Green color
                color: [1, 1, 1, 1]  # White text

            # Error label will also be centered
            Label:
                id: error_label
                text: ""
                size_hint_y: None
                height: "40dp"
                color: [1, 0, 0, 1]  # Red color for error messages
                halign: "center"
                valign: "middle"
                text_size: self.size  # Make sure text is centered

     # Right side: Airport List (Initially Hidden)
    BoxLayout:
        orientation: 'vertical'
        size_hint: None, None  # Disable automatic resizing
        size: "100dp", "300dp"  # You can adjust the size as needed
        pos_hint: {"center_x": 0.7, "center_y": 0.4}  # Center the BoxLayout
        padding: 20

        Button:
            text: "ℹ️ Airports"
            size_hint_y: None
            height: "40dp"
            on_press: root.show_airport_list()

        Label:
            id: airport_list
            text: ""  # Initially empty
            color: (1, 1, 1, 1)
            size_hint_y: None
            height: "200dp"



<SecondScreen>:
    name: "second"
    
    BoxLayout:
        orientation: 'vertical'
        padding: 10
        spacing: 10
        size_hint: 1, 1

        # Filters Section (At the top of the screen)
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: "60dp"  # Set a specific height for the filters section
            spacing: 10

            Label:
                text: "Airline:"
                size_hint_x: None
                width: "50dp"

            Spinner:
                id: airline_filter
                text: "All"  # Default value
                values: ["All"]  # This will be updated dynamically
                size_hint_x: None
                width: "150dp"
            
            Label:
                text: "Cost:"
                size_hint_x: None
                width: "50dp"

            Spinner:
                id: cost_filter
                text: "All"  # Default value
                values: ["All", "$0-$200", "$200-$400", "$400-$600", "$600+"]
                size_hint_x: None
                width: "150dp"

            Label:
                text: "Layovers:"
                size_hint_x: None
                width: "80dp"

            Spinner:
                id: layover_filter
                text: "All"  # Default value
                values: ["All", "0", "1", "2"]
                size_hint_x: None
                width: "100dp"
            
            # Submit Button to apply filters
            Button:
                text: "Apply Filters"
                size_hint: None, None
                size: 150, 50
                pos_hint: {"center_x": 0.5}
                on_press: root.apply_filters()

        # Routes and Map Section (Below filters)
        BoxLayout:
            orientation: 'horizontal'
            spacing: 10
            size_hint_y: 1  # Allow it to take the remaining vertical space
            padding: 10, 10, 10, 10  # Add padding around the routes and map section

            # Routes List (Left side of the screen)
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.4  # Left side for routes list
                id: routes_box
                height: "300dp"  # Set a specific height for the routes section
                ScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    GridLayout:
                        id: routes_grid
                        cols: 1
                        size_hint_y: None
                        height: self.minimum_height  # Adjust height based on content
                        padding: [0, 10, 0, 10]  # Padding for spacing between route buttons
                        spacing: 10  # Spacing between route buttons

            # Map Section (Right side of the screen)
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.6  # Right side for map
                MapView:
                    id: map_view
                    zoom: 5
                    size_hint_x: 1  # Full width within the right section

