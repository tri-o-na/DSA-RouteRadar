ScreenManager:
    FirstScreen:
    SecondScreen:

<FirstScreen>:
    name: "first"
    
    AnchorLayout:
        anchor_x: 'center'
        anchor_y: 'center'

        BoxLayout:
            orientation: 'vertical'
            spacing: 20
            size_hint: None, None
            size: 400, 350  # Increased height for error message

            BoxLayout:
                orientation: 'horizontal'
                size_hint: None, None
                size: 400, 50
                Label:
                    text: "Departing Airport:"
                    size_hint: None, None
                    size: 150, 40
                    halign: "left"
                    valign: "middle"
                    text_size: self.size
                TextInput:
                    id: text_input1
                    hint_text: "Type here..."
                    size_hint: None, None
                    size: 250, 40

            BoxLayout:
                orientation: 'horizontal'
                size_hint: None, None
                size: 400, 50
                Label:
                    text: "Arriving Airport:"
                    size_hint: None, None
                    size: 150, 40
                    halign: "left"
                    valign: "middle"
                    text_size: self.size
                TextInput:
                    id: text_input2
                    hint_text: "Type here..."
                    size_hint: None, None
                    size: 250, 40

            BoxLayout:
                orientation: "horizontal"
                size_hint: None, None
                size: 400, 50
                Label:
                    text: "Select option:"
                    size_hint: None, None
                    size: 150, 40
                Spinner:
                    id: dropdown
                    text: "nil"
                    values: ["nil", "Option 1", "Option 2", "Option 3"]
                    size_hint: None, None
                    size: 250, 40

            Label:
                id: error_label
                text: ""
                color: 1, 0, 0, 1  # Red error text
                size_hint: None, None
                size: 400, 30
                halign: "center"
                valign: "middle"
                text_size: self.size

            Button:
                text: "Submit"
                size_hint: None, None
                size: 150, 50
                pos_hint: {"center_x": 0.5}
                on_press: root.on_submit()

<SecondScreen>:
    name: "second"

    BoxLayout:
        orientation: "vertical"
        size_hint: 1, 1
        padding: 10

        Button:
            text: "Back"
            size_hint: None, None
            size: 100, 50
            pos_hint: {"x": 0, "top": 1}
            on_press: root.on_back()

        Label:
            text: "This is the second screen"
            font_size: 20
            size_hint_y: None
            height: 50
